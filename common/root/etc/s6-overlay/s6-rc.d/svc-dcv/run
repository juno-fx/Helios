#!/usr/bin/with-contenv bash

set -e

# Only run in DCV mode
if [ "${REMOTE_PROTOCOL}" != "dcv" ]; then
	echo "svc-dcv: REMOTE_PROTOCOL=${REMOTE_PROTOCOL}, exiting (DCV disabled)"
	exec sleep infinity
fi

# Wait for the X server on ${DISPLAY} to be ready before starting DCV.
# s6 "started" for svc-xvfb only means the run script was exec'd, not that
# the X display exists yet. If dcvserver starts first, its console-session
# agent crash-loops on the missing display and clients that connect during
# that window get "No session is available or you are not authorised".
echo "Waiting for X display ${DISPLAY} to be ready..."
while ! xset q &>/dev/null; do
	sleep 0.5
done
echo "X display ${DISPLAY} is ready."

# Surface DCV logs to container output. dcvserver only logs to files, so
# session/agent failures (the reason a client sees "No session is available")
# are invisible in `docker logs` without this.
DCV_LOG_DIR="${HOME}/.local/share/NICE/dcv/log"
mkdir -p "${DCV_LOG_DIR}"
pkill -f "tail .*NICE/dcv/log" 2>/dev/null || true
tail -n +1 -F \
	"${DCV_LOG_DIR}/server.log" \
	"${DCV_LOG_DIR}/agent.root.console.log" 2>/dev/null &

# Handle a restart: the /usr/bin/dcvserver wrapper does not exec the real
# binary, so a previous instance survives service restart and keeps the web
# port bound. Clean up before starting.
pkill -f "dcv/dcvserver" 2>/dev/null && sleep 2 || true
pkill -f "dcv/dcvagent" 2>/dev/null || true

# dcvserver launched outside systemd reads ${HOME}/.config/dcv/dcv.conf and
# ignores /etc/dcv/dcv.conf — mirror the config generated by init-dcv-config
# to where this process will actually read it.
mkdir -p "${HOME}/.config/dcv"
cp -f /etc/dcv/dcv.conf "${HOME}/.config/dcv/dcv.conf"

echo "Starting DCV Server..."

mkdir -p /run/dcv /run/dcvlogon

# Internal port only — nginx serves ${PREFIX} on 3000 and proxies to it
# (same architecture as Selkies with its 8081 backend, see svc-nginx)
DCV_ARGS="-d --web-port 8082 --auth none --create-session --session-type=console --display ${DISPLAY}${DCV_LICENSE_FILE:+ --license-file ${DCV_LICENSE_FILE}}"

exec /usr/bin/dcvserver ${DCV_ARGS}
